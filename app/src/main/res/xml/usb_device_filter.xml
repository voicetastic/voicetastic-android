<?xml version="1.0" encoding="utf-8"?>
<!--
  USB device filter for Meshtastic boards. Covers the four serial-bridge chips
  found on virtually every Meshtastic-supported board:

    - Silicon Labs CP210x   (T-Beam, T-Echo, Heltec V2/V3, RAK 4631 dock, …)
    - WCH CH9102 / CH340    (Heltec V3 newer revisions, LilyGO LoRa boards)
    - FTDI FT232            (DIY builds, some Station G2)
    - USB CDC ACM           (RP2040 / nRF52 native USB: RAK11200, T-Deck, …)

  VID/PIDs are matched in decimal as required by the Android USB framework.
-->
<resources>
    <!-- Silicon Labs CP210x family -->
    <usb-device vendor-id="4292" product-id="60000" /> <!-- 0x10C4 / 0xEA60 CP2102/CP2102N -->
    <usb-device vendor-id="4292" product-id="60016" /> <!-- 0x10C4 / 0xEA70 CP2105 -->
    <usb-device vendor-id="4292" product-id="60017" /> <!-- 0x10C4 / 0xEA71 CP2108 -->

    <!-- WCH CH340 / CH341 / CH9102 -->
    <usb-device vendor-id="6790" product-id="29987" /> <!-- 0x1A86 / 0x7523 CH340 -->
    <usb-device vendor-id="6790" product-id="21795" /> <!-- 0x1A86 / 0x5523 CH341 -->
    <usb-device vendor-id="6790" product-id="21972" /> <!-- 0x1A86 / 0x55D4 CH9102 -->

    <!-- FTDI FT232 / FT231 -->
    <usb-device vendor-id="1027" product-id="24577" /> <!-- 0x0403 / 0x6001 FT232R -->
    <usb-device vendor-id="1027" product-id="24592" /> <!-- 0x0403 / 0x6010 FT2232 -->
    <usb-device vendor-id="1027" product-id="24596" /> <!-- 0x0403 / 0x6014 FT232H -->
    <usb-device vendor-id="1027" product-id="24597" /> <!-- 0x0403 / 0x6015 FT231X -->

    <!-- USB CDC ACM (nRF52 / RP2040 native USB) -->
    <usb-device vendor-id="9114"  product-id="33012" /> <!-- 0x239A / 0x80F4 Adafruit nRF52 -->
    <usb-device vendor-id="11914" product-id="10" />     <!-- 0x2E8A / 0x000A RP2040 -->
    <usb-device vendor-id="11914" product-id="5" />      <!-- 0x2E8A / 0x0005 RP2040 boot -->
</resources>

